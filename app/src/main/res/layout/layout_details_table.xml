<?xml version="1.0" encoding="utf-8"?>
<merge
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

	<LinearLayout
		android:id="@+id/meta_table"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginHorizontal="@dimen/screen_padding"
		android:layout_marginTop="@dimen/margin_normal"
		android:orientation="vertical"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/status_strip">

		<!-- Row 1: Source | Translation -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_manga_source"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_source_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/source"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_source"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:background="@drawable/custom_selectable_item_background"
						android:drawablePadding="6dp"
						android:pointerIcon="hand"
						android:singleLine="true"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="MangaSource" />
				</LinearLayout>
			</LinearLayout>

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_language"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_translation_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/translation"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_translation"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:drawablePadding="6dp"
						android:singleLine="true"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="English" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>

		<!-- Row 2: Chapters with inline progress -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<ImageView
				android:layout_width="16dp"
				android:layout_height="16dp"
				android:layout_marginTop="2dp"
				android:contentDescription="@null"
				android:src="@drawable/ic_book_page"
				app:tint="?colorPrimary" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="10dp"
				android:layout_weight="1"
				android:orientation="vertical">

				<TextView
					android:id="@+id/textView_chapters_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:letterSpacing="0.08"
					android:singleLine="true"
					android:text="@string/chapters"
					android:textAppearance="?textAppearanceLabelSmall"
					android:textColor="?android:textColorSecondary" />

				<TextView
					android:id="@+id/textView_chapters"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:singleLine="true"
					android:textAppearance="?textAppearanceBodyMedium"
					tools:text="42 of 256" />

				<com.google.android.material.progressindicator.LinearProgressIndicator
					android:id="@+id/progress"
					style="?linearProgressIndicatorStyle"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="4dp"
					android:indeterminate="false"
					android:max="100"
					app:trackColor="?android:colorBackground"
					tools:progress="12" />
			</LinearLayout>
		</LinearLayout>

		<!-- Row 3: On device (toggled in code) -->
		<LinearLayout
			android:id="@+id/meta_local_row"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:paddingVertical="10dp"
			android:visibility="gone"
			tools:visibility="visible">

			<ImageView
				android:layout_width="16dp"
				android:layout_height="16dp"
				android:contentDescription="@null"
				android:src="@drawable/ic_storage"
				app:tint="?colorPrimary" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="10dp"
				android:layout_weight="1"
				android:orientation="vertical">

				<TextView
					android:id="@+id/textView_local_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:letterSpacing="0.08"
					android:singleLine="true"
					android:text="@string/on_device"
					android:textAppearance="?textAppearanceLabelSmall"
					android:textColor="?android:textColorSecondary" />

				<TextView
					android:id="@+id/textView_local"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:background="@drawable/custom_selectable_item_background"
					android:singleLine="true"
					android:textAppearance="?textAppearanceBodyMedium"
					tools:text="25 Mb" />
			</LinearLayout>
		</LinearLayout>

	</LinearLayout>

</merge>
