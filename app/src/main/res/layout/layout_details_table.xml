<?xml version="1.0" encoding="utf-8"?>
<merge
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

	<LinearLayout
		android:id="@+id/meta_table"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginHorizontal="@dimen/screen_padding"
		android:layout_marginTop="@dimen/margin_normal"
		android:orientation="vertical"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toBottomOf="@id/barrier_header">

		<!-- Row 1: Source | Translation -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:baselineAligned="false"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_manga_source"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_source_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/source"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_source"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:background="@drawable/custom_selectable_item_background"
						android:drawablePadding="6dp"
						android:pointerIcon="hand"
						android:singleLine="true"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="MangaSource" />
				</LinearLayout>
			</LinearLayout>

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_language"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_translation_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/translation"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_translation"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:drawablePadding="6dp"
						android:singleLine="true"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="English" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>

		<!-- Row 2: Author | State -->
		<LinearLayout
			android:id="@+id/meta_author_state_row"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:baselineAligned="false"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<LinearLayout
				android:id="@+id/meta_author_cell"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_user"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_author_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/author"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_author"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:ellipsize="end"
						android:maxLines="2"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="Author name" />
				</LinearLayout>
			</LinearLayout>

			<LinearLayout
				android:id="@+id/meta_state_cell"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_play"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_state_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/state"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_state"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:singleLine="true"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="Ongoing" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>

		<!-- Row 3: Rating | On device -->
		<LinearLayout
			android:id="@+id/meta_rating_local_row"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:baselineAligned="false"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<LinearLayout
				android:id="@+id/meta_rating_cell"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_star_small"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_rating_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/rating"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<RatingBar
						android:id="@+id/ratingBar_rating"
						style="?ratingBarStyleSmall"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:isIndicator="true"
						android:numStars="5"
						android:stepSize="0.5" />
				</LinearLayout>
			</LinearLayout>

			<LinearLayout
				android:id="@+id/meta_local_cell"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_vertical"
				android:orientation="horizontal"
				android:visibility="gone"
				tools:visibility="visible">

				<ImageView
					android:layout_width="16dp"
					android:layout_height="16dp"
					android:contentDescription="@null"
					android:src="@drawable/ic_storage"
					app:tint="?colorPrimary" />

				<LinearLayout
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="10dp"
					android:layout_weight="1"
					android:orientation="vertical">

					<TextView
						android:id="@+id/textView_local_label"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:letterSpacing="0.08"
						android:singleLine="true"
						android:text="@string/on_device"
						android:textAppearance="?textAppearanceLabelSmall"
						android:textColor="?android:textColorSecondary" />

					<TextView
						android:id="@+id/textView_local"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:background="@drawable/custom_selectable_item_background"
						android:singleLine="true"
						android:textAppearance="?textAppearanceBodyMedium"
						tools:text="25 Mb" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>

		<!-- Row 4: Chapters (full width) -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<ImageView
				android:layout_width="16dp"
				android:layout_height="16dp"
				android:contentDescription="@null"
				android:src="@drawable/ic_book_page"
				app:tint="?colorPrimary" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="10dp"
				android:layout_weight="1"
				android:orientation="vertical">

				<TextView
					android:id="@+id/textView_chapters_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:letterSpacing="0.08"
					android:singleLine="true"
					android:text="@string/chapters"
					android:textAppearance="?textAppearanceLabelSmall"
					android:textColor="?android:textColorSecondary" />

				<TextView
					android:id="@+id/textView_chapters"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:singleLine="true"
					android:textAppearance="?textAppearanceBodyMedium"
					tools:text="42 of 256" />
			</LinearLayout>
		</LinearLayout>

		<!-- Row 5: Progress (full width with bar) -->
		<LinearLayout
			android:id="@+id/meta_progress_row"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:paddingVertical="10dp">

			<ImageView
				android:layout_width="16dp"
				android:layout_height="16dp"
				android:layout_marginTop="2dp"
				android:contentDescription="@null"
				android:src="@drawable/ic_history"
				app:tint="?colorPrimary" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="10dp"
				android:layout_weight="1"
				android:orientation="vertical">

				<TextView
					android:id="@+id/textView_progress_label"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:letterSpacing="0.08"
					android:singleLine="true"
					android:text="@string/progress"
					android:textAppearance="?textAppearanceLabelSmall"
					android:textColor="?android:textColorSecondary" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal">

					<com.google.android.material.progressindicator.LinearProgressIndicator
						android:id="@+id/progress"
						style="?linearProgressIndicatorStyle"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:indeterminate="false"
						android:max="100"
						app:trackColor="?android:colorBackground"
						tools:progress="49" />

					<TextView
						android:id="@+id/textView_progress"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginStart="8dp"
						android:singleLine="true"
						android:textAppearance="?textAppearanceLabelMedium"
						tools:text="49%" />
				</LinearLayout>
			</LinearLayout>
		</LinearLayout>

	</LinearLayout>

</merge>
